# Backend URLs — no hardcoded ports in code, set here per environment.
#
# NEXT_PUBLIC_API_URL          -> primary backend: Flask (app.py), local dev port 5001
# NEXT_PUBLIC_API_URL_FALLBACK -> fallback: server.js, deployed via vercel.json,
#                                 local default is 10000 (process.env.PORT || 10000)
#
# Two other ports exist elsewhere in this repo and are NOT wired as the
# fallback (confirm with the team before using either):
#   4000 -> "browser ai capabilities/index.js", a separate standalone Node agent
#   8443 -> scan.js's own default --base-url, assumed for a signed-request
#            "secure-api" server -- may or may not be server.js itself
#
# Production (Vercel etc): set both to real HTTPS domains, no ports --
# Vercel injects its own PORT env var and serves over standard HTTPS.
NEXT_PUBLIC_API_URL=http://localhost:5001
NEXT_PUBLIC_API_URL_FALLBACK=http://localhost:10000

COHERE_API_KEY=
JWT_SECRET=

# ── auth-service (Google OAuth + OTP) — required, previously undocumented ──
GOOGLE_CLIENT_ID=
TURNSTILE_SECRET_KEY=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
FLASK_API_URL=http://localhost:5001
FRONTEND_URLS=http://localhost:3000,http://localhost:5173

# ── secure-api — shared secret for x-signature HMAC verification ──
MASTER_KEY=

# ── ai.web_search node (SerpApi) ──
SERPAPI_API_KEY=

# ── backup_service.py — periodic knowledge-base snapshots ──
BACKUP_S3_BUCKET=
BACKUP_S3_ENDPOINT_URL=
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=
BACKUP_INTERVAL_MINUTES=15

# ── admin_routes.py — operator-only backup status/restore (X-Admin-Key header) ──
ADMIN_KEY=

# ── auth.py — server-to-server key auth-service uses to call /api/auth/oauth-issue ──
INTERNAL_SERVICE_KEY=

# ── OneDrive cloud backup (premium/executive feature) ──
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_REDIRECT_URI=http://localhost:5001/api/premium/onedrive/callback
