{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {

    "NodeManifest": {
      "description": "Every node must declare this before it can be added to a flow.",
      "type": "object",
      "required": ["node_id", "node_name", "generated_by", "permissions", "actions"],
      "properties": {
        "node_id": {
          "type": "string",
          "description": "Unique identifier for this node instance (UUID)"
        },
        "node_name": {
          "type": "string",
          "description": "Human-readable name e.g. 'Upload PDFs to Dropbox'"
        },
        "generated_by": {
          "type": "string",
          "enum": ["user", "ai"],
          "description": "Whether node was hand-built or AI-generated"
        },
        "permissions": {
          "type": "array",
          "description": "List of permission levels this node requires",
          "items": {
            "type": "string",
            "enum": ["read_only", "write_modify", "system_level", "network", "api_call"]
          }
        },
        "actions": {
          "type": "array",
          "description": "Specific actions this node will attempt",
          "items": {
            "type": "object",
            "required": ["action_type", "target", "scope"],
            "properties": {
              "action_type": {
                "type": "string",
                "enum": [
                  "READ", "WRITE", "DELETE", "MOVE",
                  "POST", "GET", "PATCH",
                  "SHELL_EXEC", "UI_CONTROL"
                ]
              },
              "target": {
                "type": "string",
                "description": "What is being acted on e.g. '~/Downloads', 'api.spotify.com', 'Terminal'"
              },
              "scope": {
                "type": "string",
                "description": "Specific path or endpoint e.g. '~/Downloads/*.pdf', '/playlists/{id}/tracks'"
              }
            }
          }
        },
        "safe_primitives_only": {
          "type": "boolean",
          "description": "True if node only uses Safe Wrapper Functions — no raw shell scripts"
        },
        "sandbox_validated": {
          "type": "boolean",
          "description": "True if code has been validated in sandbox before execution"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },

    "AppPermissions": {
      "description": "User-defined registry of approved apps and their allowed scopes.",
      "type": "object",
      "required": ["user_id", "approved_apps"],
      "properties": {
        "user_id": {
          "type": "string",
          "description": "Owner of these permissions"
        },
        "approved_apps": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["app_id", "app_name", "allowed_actions", "allowed_scopes"],
            "properties": {
              "app_id": {
                "type": "string",
                "description": "Unique identifier e.g. 'spotify', 'dropbox', 'terminal'"
              },
              "app_name": {
                "type": "string",
                "description": "Display name e.g. 'Spotify', 'Dropbox', 'Terminal'"
              },
              "api_key_ref": {
                "type": "string",
                "description": "Reference to stored API key (never the key itself)"
              },
              "allowed_actions": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": ["READ", "WRITE", "DELETE", "MOVE", "POST", "GET", "PATCH", "SHELL_EXEC", "UI_CONTROL"]
                }
              },
              "allowed_scopes": {
                "type": "array",
                "description": "Specific paths or endpoints the agent is allowed to touch",
                "items": { "type": "string" }
              },
              "approved_at": {
                "type": "string",
                "format": "date-time"
              },
              "expires_at": {
                "type": ["string", "null"],
                "format": "date-time",
                "description": "Optional expiry — null means no expiry"
              }
            }
          }
        }
      }
    }

  },

  "examples": {
    "node_manifest_example": {
      "node_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
      "node_name": "Upload PDFs to Dropbox Tax folder",
      "generated_by": "ai",
      "permissions": ["read_only", "api_call"],
      "actions": [
        {
          "action_type": "READ",
          "target": "~/Downloads",
          "scope": "~/Downloads/*.pdf"
        },
        {
          "action_type": "POST",
          "target": "api.dropboxapi.com",
          "scope": "/2/files/upload"
        }
      ],
      "safe_primitives_only": true,
      "sandbox_validated": false,
      "created_at": "2026-04-11T10:00:00Z"
    },

    "app_permissions_example": {
      "user_id": "user_001",
      "approved_apps": [
        {
          "app_id": "spotify",
          "app_name": "Spotify",
          "api_key_ref": "env:SPOTIFY_API_KEY",
          "allowed_actions": ["GET", "POST"],
          "allowed_scopes": ["/playlists", "/playlists/{id}/tracks"],
          "approved_at": "2026-04-11T09:00:00Z",
          "expires_at": null
        },
        {
          "app_id": "local_filesystem",
          "app_name": "Local File System",
          "api_key_ref": null,
          "allowed_actions": ["READ", "WRITE", "MOVE"],
          "allowed_scopes": ["~/Documents", "~/Downloads"],
          "approved_at": "2026-04-11T09:00:00Z",
          "expires_at": null
        }
      ]
    }
  }
}
