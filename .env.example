# ── BACKEND (.env in /backend) ──────────────────────────────────

# Google OAuth  →  console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your_google_client_id_here

# Cloudflare Turnstile SECRET  →  dash.cloudflare.com → Turnstile
TURNSTILE_SECRET_KEY=your_turnstile_secret_key_here

# SMTP (use SendGrid / Gmail App Password / Mailgun etc.)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=apikey
SMTP_PASS=your_smtp_password_or_api_key
OTP_EMAIL_FROM=noreply@yourdomain.com

# App
PORT=5000
FRONTEND_URL=http://localhost:5173

# ── FRONTEND (.env in /frontend) ─────────────────────────────────

# Google OAuth  →  same client ID as above (safe to expose - it's public)
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# Cloudflare Turnstile SITE KEY  →  dash.cloudflare.com → Turnstile (safe to expose)
VITE_TURNSTILE_SITE_KEY=your_turnstile_site_key_here

# Backend URL
VITE_API_URL=http://localhost:5000
