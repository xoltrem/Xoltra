{
  "version": 2,
  "builds": [
    { "src": "backend/secure-api/server.js", "use": "@vercel/node" },
    { "src": "backend/auth-service/auth-server.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/auth/(.*)", "dest": "backend/auth-service/auth-server.js" },
    { "src": "/(.*)", "dest": "backend/secure-api/server.js" }
  ]
}
