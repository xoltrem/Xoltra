{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "auth-server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/auth/(.*)",
      "dest": "/auth-server.js"
    },
    {
      "src": "/(.*)",
      "dest": "/server.js"
    }
  ]
}