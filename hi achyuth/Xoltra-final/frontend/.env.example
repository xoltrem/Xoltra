# ── Flask backend (app.py) ──
NEXT_PUBLIC_API_URL=http://localhost:5001
NEXT_PUBLIC_API_URL_FALLBACK=http://localhost:4000

# ── Node auth-service (Google OAuth + OTP login) ──
NEXT_PUBLIC_AUTH_SERVICE_URL=http://localhost:5000

# ── Google Identity Services button (public client ID, safe to expose) ──
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# ── Cloudflare Turnstile widget (public site key, safe to expose) ──
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
