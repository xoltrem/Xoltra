# PLACEHOLDER — the Google button will now render, but clicking it will
# fail until you replace this with a real client ID from Google Cloud
# Console (APIs & Services -> Credentials -> OAuth client ID -> Web app).
NEXT_PUBLIC_GOOGLE_CLIENT_ID=REPLACE_ME.apps.googleusercontent.com

# PLACEHOLDER — same deal, from the Cloudflare dashboard (Turnstile, free).
# Leave blank instead of a fake value if you don't want the widget to try
# to render at all.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
