{
  "manifest_version": 3,
  "name": "Portal",
  "version": "1.0",
  "description": "Open duck.ai in incognito and summarize conversations",
  "permissions": ["tabs", "storage", "activeTab", "scripting", "windows"],
  "host_permissions": [
    "https://duck.ai/*",
    "https://api.cohere.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Portal"
  },
  "content_scripts": [
    {
      "matches": ["https://duck.ai/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}